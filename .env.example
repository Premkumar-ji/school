# MongoDB Connection URI
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority&appName=Cluster0

# Admin Credentials (Server-side only)
ADMIN_EMAIL_1=admin@school.com
ADMIN_PASSWORD_1=admin123
ADMIN_EMAIL_2=staff@school.com
ADMIN_PASSWORD_2=staff123

# Session Secret for API Authentication
ADMIN_SESSION_SECRET=your_random_secret_here
